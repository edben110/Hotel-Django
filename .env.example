# =============================================================================
# HOTEL DJANGO - ENVIRONMENT TEMPLATE FOR RENDER
# Copy this file to .env and fill in values per environment.
# Do not commit real secrets.
# =============================================================================

# ----------------------------------------------------------------------------
# Backend / Django
# ----------------------------------------------------------------------------
SECRET_KEY=replace-me-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-backend.onrender.com,localhost,127.0.0.1
BACKEND_URL=https://your-backend.onrender.com
API_URL=https://your-backend.onrender.com
FRONTEND_URL=https://your-frontend.onrender.com
RENDER_EXTERNAL_HOSTNAME=your-backend.onrender.com

# ----------------------------------------------------------------------------
# CORS / CSRF
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://your-backend.onrender.com,https://your-frontend.onrender.com,http://localhost:8000,http://127.0.0.1:8000

# ----------------------------------------------------------------------------
# API endpoints for external frontend frameworks
# ----------------------------------------------------------------------------
VITE_API_URL=https://your-backend.onrender.com
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
REACT_APP_API_URL=https://your-backend.onrender.com

# ----------------------------------------------------------------------------
# Authentication / session behavior
# ----------------------------------------------------------------------------
LOGIN_URL=/auth/login/
LOGIN_REDIRECT_URL=/auth/
LOGOUT_REDIRECT_URL=/auth/login/
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# ----------------------------------------------------------------------------
# Email / SMTP
# ----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=replace-me
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=your-email@example.com
EMAIL_SUBJECT_PREFIX=[Hotel] 

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Timezone / Locale
# ----------------------------------------------------------------------------
TIME_ZONE=UTC
LANGUAGE_CODE=es-es
USE_TZ=True
USE_I18N=True

# ----------------------------------------------------------------------------
# PostgreSQL - Render Managed Database
# Preferred option: use DATABASE_URL from Render
# ----------------------------------------------------------------------------
DATABASE_URL=postgres://db_user:db_password@db_host:5432/db_name
DB_NAME=db_name
DB_USER=db_user
DB_PASSWORD=db_password
DB_HOST=db_host
DB_PORT=5432

# ----------------------------------------------------------------------------
# Optional local development defaults
# ----------------------------------------------------------------------------
# If DATABASE_URL is not set, the project falls back to SQLite locally.
LOCAL_DEV=True
